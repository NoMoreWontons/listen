# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Supabase: Project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # service_role, stays server-side only

# Anthropic: console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional (defaults shown)
WHISPER_MODEL=large-v3-turbo   # tiny for a fast first run
RETENTION_DAYS=7
OBSIDIAN_VAULT=               # blank = ~/College Lectures
SEMESTER_OVERRIDE=            # blank = auto from date; e.g. Bridge to force a label

# Notion fallback (AI meeting-note taker). Feature stays OFF until NOTION_TOKEN is set.
# Get token: https://www.notion.so/my-integrations (internal integration, copy secret),
# then share the target database with the integration.
NOTION_TOKEN=
NOTION_DB_ID=
NOTION_POLL_MIN=10
